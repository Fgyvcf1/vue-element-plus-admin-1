# 环境
VITE_NODE_ENV=development

# 接口前缀
VITE_API_BASE_PATH=/api

# 打包路径
VITE_BASE_PATH=/

# 标题
VITE_APP_TITLE=ElementAdmin

# 是否全量引入element-plus样式
VITE_USE_ALL_ELEMENT_PLUS_STYLE=true

# 是否开启mock
VITE_USE_MOCK=false

# 是否使用在线图标
VITE_USE_ONLINE_ICON=false

# 是否隐藏全局设置按钮
VITE_HIDE_GLOBAL_SETTING=false

# 是否禁用图标清理插件（提高开发启动速度）
VITE_DISABLE_PURGE_ICONS=true

# 是否禁用进度条插件（可选）
VITE_SHOW_PROGRESS=false

# 是否禁用ESLint检查（开发期间可以禁用以提高性能）
VITE_DISABLE_ESLINT=true